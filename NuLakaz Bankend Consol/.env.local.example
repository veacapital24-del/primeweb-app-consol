# Copy to .env.local and fill in
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Storefront URL (used to render bio-link copy in the Reels admin)
NEXT_PUBLIC_STOREFRONT_URL=http://localhost:3000

# WhatsApp Cloud API (optional — leave blank to test with deep-links only)
WHATSAPP_VERIFY_TOKEN=prime-mauritius-verify
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_BUSINESS_PHONE=23057000000
